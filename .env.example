# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_TELEGRAM_ID=your_id

# WhatsApp
WHATSAPP_BUSINESS_ID=your_biz_id
WHATSAPP_ACCESS_TOKEN=your_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_id

# GCP & Firebase
GCP_PROJECT_ID=chatbot-moderation-dev
FIRESTORE_DB_NAME= # Optional: Leave empty for default, or set to 'chatbot-db'
FIRESTORE_EMULATOR_HOST=firestore:8080
GCP_REGION=asia-southeast1
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/your-project-id/locations/global/workloadIdentityPools/your-pool-id/providers/your-provider-id
GCP_SERVICE_ACCOUNT=your-email@your-project-id.iam.gserviceaccount.com

# Hugging Face
HUGGINGFACE_API_TOKEN=your_hf_token

# App Config
DEBUG=True
PORT=8080
LOG_LEVEL=INFO
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app
